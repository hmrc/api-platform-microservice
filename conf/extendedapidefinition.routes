# microservice specific routes

GET        /                                                        uk.gov.hmrc.apiplatformmicroservice.apidefinition.controllers.extended.ExtendedApiDefinitionController.fetchApiDefinitionsForCollaborator(developerId: Option[SimpleUserId])
GET        /subscribed                                              uk.gov.hmrc.apiplatformmicroservice.apidefinition.controllers.extended.ExtendedApiDefinitionController.fetchSubscribedApiDefinitionsForCollaborator(developerId: SimpleUserId)
GET        /:serviceName                                            uk.gov.hmrc.apiplatformmicroservice.apidefinition.controllers.extended.ExtendedApiDefinitionController.fetchExtendedApiDefinitionForCollaborator(serviceName: SimpleServiceName, developerId: Option[SimpleUserId])
GET        /:serviceName/:version/documentation/*resource           uk.gov.hmrc.apiplatformmicroservice.apidefinition.controllers.extended.ExtendedApiDefinitionController.fetchApiDocumentationResource(serviceName: SimpleServiceName, version: SimpleApiVersionNbr, resource: String)
GET        /:serviceName/:version/specification                     uk.gov.hmrc.apiplatformmicroservice.apidefinition.controllers.extended.ApiSpecificationController.fetchApiSpecification(serviceName: SimpleServiceName, version:  SimpleApiVersionNbr)
