# microservice specific routes

# routes need fixing but will need changes to TPDFE

GET        /                              uk.gov.hmrc.apiplatformmicroservice.combinedapis.controllers.CombinedApisController.fetchAllApis()
GET        /developer                     uk.gov.hmrc.apiplatformmicroservice.combinedapis.controllers.CombinedApisController.getCombinedApisForDeveloper(developerId: Option[SimpleUserId])
